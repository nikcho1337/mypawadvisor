# Pinterest API v5 credentials — copy to .env and fill in.
# Get App ID + secret from https://developers.pinterest.com/apps/
PINTEREST_APP_ID=1575850
PINTEREST_APP_SECRET=your_app_secret_here
# Must EXACTLY match a redirect URI registered in the app settings.
PINTEREST_REDIRECT_URI=https://mypawadvisor.com/pinterest-callback
